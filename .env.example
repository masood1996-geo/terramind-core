# TerraMind Core v4.0 — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4100
HOST=0.0.0.0

# ─── NASA FIRMS (Fire Information for Resource Management System) ────────────
# Free API key from: https://firms.modaps.eosdis.nasa.gov/api/area/
# Without this key, fire detection is disabled (USGS/EONET/NOAA still work).
FIRMS_MAP_KEY=your_firms_map_key_here

# ─── Cache ───────────────────────────────────────────────────────────────────
# Cache TTL in milliseconds (default: 60s)
CACHE_TTL=60000

# Auto-refresh interval in milliseconds (default: 2 minutes)
REFRESH_INTERVAL=120000

# ─── GeoScience AI Assistant (Kilo Gateway) ──────────────────────────────────
# API key from: https://app.kilo.ai — used for the AI GeoScience chat assistant.
# Without this key, the built-in knowledge engine is used as a fallback.
KILOCODE_API_KEY=your_kilo_api_key_here

# ─── GlobalBuildingAtlas (Building Exposure) ─────────────────────────────────
# WFS endpoint for GlobalBuildingAtlas building footprint queries.
# Default: https://tubvsig-so2sat-vm1.srv.mwn.de/geoserver/ows (TU Munich)
# No API key needed — completely free. Override only if using a custom mirror.
# GBA_WFS_URL=https://tubvsig-so2sat-vm1.srv.mwn.de/geoserver/ows

